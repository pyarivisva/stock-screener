POSTGRES_USER=stock_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=stock_screener
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
PGADMIN_DEFAULT_EMAIL=admin@stockscreener.local
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_password
# DATABASE_URL=postgresql://stock_user:change_me_strong_password@127.0.0.1:5433/stock_screener

# Celery broker / result (Redis DB terpisah dari cache API — PRD §10.1)
REDIS_CELERY_BROKER_URL=redis://127.0.0.1:6379/1
REDIS_CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
CELERY_TIMEZONE=Asia/Jakarta

# Redis cache API (DB 0). Kosongkan agar URL dibangun dari host/port + /0
REDIS_CACHE_URL=

# API Connector — wajib sama antara FastAPI dan Streamlit (PRD §12.1)
API_SECRET_KEY=change_me_connector_api_key

# Alpha Vantage (sumber sekunder ETL — PRD §6.1). Kosongkan jika hanya memakai yfinance.
ALPHA_VANTAGE_API_KEY=